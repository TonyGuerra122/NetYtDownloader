<Window x:Class="GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GUI"
        xmlns:conv="clr-namespace:GUI.Converters"
        d:DataContext="{d:DesignInstance Type=local:MainViewModel}"
        mc:Ignorable="d"
        Title="NetYtDownloader"
        Width="900"
        SizeToContent="Height"
        MinHeight="560"
        Background="#0F0F0F"
        Icon="pack://application:,,,/Assets/icon.ico"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="ModernScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#444" CornerRadius="4"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#111827" Offset="0"/>
                <GradientStop Color="#0F0F0F" Offset="0.55"/>
                <GradientStop Color="#1F0A0A" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border MaxHeight="700"
                Margin="24"
                Padding="36"
                CornerRadius="28"
                Background="#CC181818"
                BorderBrush="#2A2A2A"
                BorderThickness="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Buscar vídeos"
                           Foreground="White"
                           FontSize="34"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                <TextBlock Grid.Row="1"
                           Text="Digite o nome de um vídeo, música, canal ou assunto do YouTube"
                           Foreground="#AAAAAA"
                           FontSize="15"
                           Margin="0,10,0,32"
                           TextAlignment="Center"/>

                <Border Grid.Row="2"
                        CornerRadius="18"
                        Background="#252525"
                        BorderBrush="#3A3A3A"
                        BorderThickness="1"
                        Height="58">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="🔎"
                                   FontSize="22"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>

                        <Grid Grid.Column="1" Margin="8,0,8,0">
                            <TextBox x:Name="SearchTextBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="White"
                                     CaretBrush="White"
                                     FontSize="17"
                                     VerticalContentAlignment="Center"
                                     Padding="0"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter"
                                    Command="{Binding SearchCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>

                            <TextBlock Text="Buscar no YouTube..."
                                       Foreground="#777777"
                                       FontSize="15"
                                       VerticalAlignment="Center"
                                       Margin="2,0,0,0"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <Button Grid.Column="2"
                            Margin="6"
                            Padding="20,0"
                            Height="40"
                            Cursor="Hand"
                            Command="{Binding SearchCommand}">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="BtnBorder"
                                        Background="#FF0033"
                                        CornerRadius="20"
                                        Padding="12,0">

                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="8"
                                      ShadowDepth="2"
                                      Opacity="0.3"/>
                                        </Border.Effect>

                                        <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">

                                            <TextBlock Text="🔎"
                                               FontSize="14"
                                               Margin="0,0,6,0"/>

                                            <TextBlock Text="Pesquisar"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>
                                        </StackPanel>
                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <!-- Hover -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BtnBorder"
                                                Property="Background"
                                                Value="#FF1A4D"/>
                                        </Trigger>

                                        <!-- Click -->
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="BtnBorder"
                                                Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>

                                        <!-- Disabled -->
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="BtnBorder"
                                                Property="Opacity"
                                                Value="0.5"/>
                                        </Trigger>

                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="3">
                    <TextBlock Text="Exemplo: curso de WPF, música lo-fi, trailer de filme..."
                               Foreground="#777777"
                               FontSize="13"
                               Margin="4,12,0,0"/>
                </StackPanel>

                <ListBox x:Name="VideosListBox"
                         Grid.Row="4"
                         ItemsSource="{Binding Videos}"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="0,24,0,0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <ListBox.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ModernScrollBar}"/>
                    </ListBox.Resources>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="IsTabStop" Value="False"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1E1E1E"
                                    CornerRadius="16"
                                    Padding="12"
                                    Margin="0,0,0,14">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="110"/>
                                    </Grid.ColumnDefinitions>

                                    <Border CornerRadius="10" ClipToBounds="True">
                                        <Image Source="{Binding ThumbnailUrl}"
                                               Width="140"
                                               Height="80"
                                               Stretch="UniformToFill"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="White"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>

                                        <TextBlock Text="{Binding Author}"
                                                   Foreground="#AAAAAA"
                                                   FontSize="12"
                                                   Margin="0,6,0,0"/>

                                        <TextBlock Text="{Binding Duration}"
                                                   Foreground="#777777"
                                                   FontSize="11"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <Button Content="▶"
                                                Height="34"
                                                Margin="0,0,0,8"
                                                Background="#2C2C2C"
                                                Foreground="White"
                                                BorderThickness="0"
                                                FontSize="14"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.OpenVideoCommand, Source={x:Reference VideosListBox}}"
                                                CommandParameter="{Binding}"/>

                                        <Button Content="⬇"
                                                Height="34"
                                                Margin="0,0,0,8"
                                                Background="#FF0033"
                                                Foreground="White"
                                                BorderThickness="0"
                                                FontSize="14"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.DownloadVideoCommand, Source={x:Reference VideosListBox}}"
                                                CommandParameter="{Binding}"/>

                                        <Button Content="🎵"
                                            Height="34"
                                            Background="#FF0033"
                                            Foreground="White"
                                            BorderThickness="0"
                                            FontSize="14"
                                            Cursor="Hand"
                                            Command="{Binding DataContext.DownloadAudioCommand, Source={x:Reference VideosListBox}}"
                                            CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Overlay precisa ficar por último -->
        <Grid Background="#AA000000"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <Grid Width="64"
                      Height="64"
                      RenderTransformOrigin="0.5,0.5">

                    <Grid.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotate"/>
                    </Grid.RenderTransform>

                    <Ellipse Width="64"
                             Height="64"
                             Stroke="#333333"
                             StrokeThickness="6"/>

                    <Path Stroke="#FF0033"
                          StrokeThickness="6"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="M 32,4 A 28,28 0 0 1 60,32"/>
                </Grid>

                <TextBlock Text="{Binding LoadingText}"
                           Foreground="White"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Margin="0,16,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <Grid.Triggers>
                <EventTrigger RoutedEvent="Grid.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                             Storyboard.TargetProperty="Angle"
                                             From="0"
                                             To="360"
                                             Duration="0:0:1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
        </Grid>
    </Grid>
</Window>